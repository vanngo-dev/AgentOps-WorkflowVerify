# Local example configuration.
# Values here are safe defaults for local development and Docker Compose.

APP_ENV=local
LOG_LEVEL=info
AGENT_MODE=simulated
HUMAN_APPROVAL_REQUIRED=true

# Non-Docker backend default. Docker Compose overrides the host to `postgres`.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/agentops_workflow

# Docker Compose PostgreSQL defaults.
POSTGRES_DB=agentops_workflow
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Browser-facing frontend API URL.
VITE_API_BASE_URL=http://localhost:8000
